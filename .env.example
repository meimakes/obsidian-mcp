# ─── Local Mode ───────────────────────────────────────────────────────────────
# Path to your Obsidian vault (absolute path)
VAULT_PATH=/Users/yourname/Documents/MyVault

# Server port
PORT=3456

# Bind address — 127.0.0.1 (default, local only) or 0.0.0.0 (all interfaces)
# Use 0.0.0.0 only with AUTH_TOKEN set or behind Tailscale/VPN
BIND_ADDRESS=127.0.0.1

# Folder where daily notes live (relative to vault root)
# Examples: "Journal", "Daily Notes", "." (vault root)
DAILY_NOTE_FOLDER=Journal

# Optional bearer token for authentication
# REQUIRED for cloud deploys — without it anyone with the URL can read/write your vault
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN=

# Maximum request body size (default: 1mb)
MAX_BODY_SIZE=1mb

# ─── Cloud Mode (Docker Compose) ─────────────────────────────────────────────
# These are only needed when using docker-compose.yml with Obsidian Headless Sync.

# Obsidian Sync auth token
# Run: docker run --rm -it --entrypoint get-token ghcr.io/belphemur/obsidian-headless-sync-docker:latest
OBSIDIAN_AUTH_TOKEN=

# Exact name of your vault in Obsidian Sync
VAULT_NAME=MyVault

# End-to-end encryption password (only if your vault has E2E encryption enabled)
VAULT_PASSWORD=

# Device name shown in Obsidian Sync history
DEVICE_NAME=obsidian-mcp-cloud
